MAILCHIMP_API_KEY=your_mailchimp_api_key_here
MAILCHIMP_AUDIENCE_ID=your_audience_id_here
MAILCHIMP_SERVER=your_server_prefix_here

# Public canonical site URL (e.g. https://athlox.com). Drives:
# - metadataBase in app/layout.tsx (resolves canonical + OG URLs)
# - same-origin allowlist in /api/subscribe
# Set this in Vercel project settings for production AND preview.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Meta Conversions API — server-side Lead event tracking
META_PIXEL_ID=your_pixel_id_here
META_CAPI_TOKEN=your_capi_access_token_here
